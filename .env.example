# Environment variables for Prodify
# Copy this file to .env and fill in the values. NEVER commit .env to git.

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection URL (used by Prisma at runtime via PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/prodify?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection URL (used by Prisma Migrate — bypasses PgBouncer)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/prodify?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Resend (transactional email) ─────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=""
